<UserControl x:Class="MotionCapture.Controls.OverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MotionCapture.Controls"
             xmlns:converters="clr-namespace:MotionCapture.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#66000000">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <UserControl.Visibility>
        <Binding Path="IsVisible" Converter="{StaticResource BoolToVisibilityConverter}"/>
    </UserControl.Visibility>
    <Grid>
        <TextBlock Text="{Binding Message}"
               FontSize="18"
               HorizontalAlignment="Center"
               Margin="0,70,0,0"
               VerticalAlignment="Top"
               Background="#B2FFFFFF"
               Height="Auto"
               Width="500"
               TextWrapping="Wrap"
               TextAlignment="Center"
               Padding="5,10"/>
        <Button Content="Ок"
                FontSize="16"
                Width="100"
                Height="45"
                Margin="0,0,0,30"
                VerticalAlignment="Bottom"
                Command="{Binding OkClickedCommand}"/>
    </Grid>
</UserControl>
